{
	"name": "starkfi-server",
	"version": "0.1.0",
	"description": "Backend for starkfi CLI — Privy auth, Starknet wallet management, signing",
	"type": "module",
	"scripts": {
		"dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
		"build": "tsc",
		"start": "node dist/src/index.js",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"dependencies": {
		"@hono/node-server": "^1.19.11",
		"@hono/zod-validator": "^0.7.6",
		"@privy-io/node": "^0.10.1",
		"hono": "^4.12.7",
		"jose": "^6.2.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^25.4.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0"
	}
}
