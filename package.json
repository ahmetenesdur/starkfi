{
	"name": "starkfi",
	"version": "0.6.1",
	"description": "AI-native Starknet DeFi CLI + MCP Server + Agent Skills — Swaps, multi-swap, batch (multicall), staking, lending, DCA, confidential transfers, simulation, portfolio, gas abstraction",
	"type": "module",
	"bin": {
		"starkfi": "./dist/index.js"
	},
	"main": "./dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"files": [
		"dist",
		"skills",
		"README.md",
		"MCP.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsx --import ./scripts/stub-peers-loader.mjs src/index.ts",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"start": "node dist/index.js",
		"mcp-start": "node dist/index.js mcp-start",
		"prepublishOnly": "pnpm run build"
	},
	"keywords": [
		"starknet",
		"defi",
		"cli",
		"mcp",
		"mcp-server",
		"ai-native",
		"agent-skills",
		"starkzap",
		"swap",
		"multi-swap",
		"batch",
		"multicall",
		"simulation",
		"portfolio",
		"staking",
		"lending",
		"gasless",
		"gas-abstraction",
		"dca",
		"confidential",
		"tongo",
		"vesu",
		"fibrous",
		"web3",
		"l2"
	],
	"author": "ahmetenesdur",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ahmetenesdur/starkfi.git"
	},
	"bugs": {
		"url": "https://github.com/ahmetenesdur/starkfi/issues"
	},
	"homepage": "https://starkfi.app",
	"engines": {
		"node": ">=18"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@types/node": "^25.5.2",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"env-paths": "^3.0.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"ora": "^9.3.0",
		"prettier": "^3.8.1",
		"starkzap": "^2.0.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@fatsolutions/tongo-sdk": "^1.4.0"
	}
}
